---
import type { Release } from "../lib/schemas";

interface Props {
  release: Release;
}

const { release } = Astro.props;
const streamLinks = Object.entries(release.links).filter(([, url]) => url);
---

<article class="release-card">
  <div class="release-info">
    <h3>{release.title}</h3>
    <p class="release-meta">
      <span class="release-type">{release.type}</span>
      <span class="release-date">{release.releaseDate}</span>
    </p>
    <p class="release-desc">{release.description}</p>
    {streamLinks.length > 0 && (
      <div class="release-links">
        {streamLinks.map(([platform, url]) => (
          <a href={url} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
            {platform}
          </a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .release-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    padding: 1.5rem;
  }

  .release-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .release-type {
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-secondary);
  }

  .release-desc {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
  }

  .release-links {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .release-links .btn {
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    text-transform: capitalize;
  }
</style>
